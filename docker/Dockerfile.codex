FROM node:20-bullseye-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    openssh-client \
    bash \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Install the Codex CLI inside the image so the container can run it directly.
# If the package name changes upstream, update this line and the README together.
RUN npm install -g @openai/codex

ENTRYPOINT ["codex"]
